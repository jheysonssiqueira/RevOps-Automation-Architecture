    {
      "parameters": {
        "jsCode": "const texto = $('Trata Dados Chatwoot1').first().json.mensagem_texto;\nconst emailMatch = texto.match(/([a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+\\.[a-zA-Z0-9._-]+)/gi);\n\n// Pega 14 números\nconst numerosApenas = texto.replace(/\\D/g, ''); \nconst cnpjMatch = numerosApenas.match(/\\d{14}/g);\nconst cnpjBruto = cnpjMatch ? cnpjMatch[0] : null;\n\n// Função sênior para validar se o CNPJ é real (evita erro 422)\nfunction validarCNPJ(cnpj) {\n    if (!cnpj || cnpj.length !== 14 || /^(\\d)\\1+$/.test(cnpj)) return false;\n    let tamanho = cnpj.length - 2;\n    let numeros = cnpj.substring(0, tamanho);\n    let digitos = cnpj.substring(tamanho);\n    let soma = 0;\n    let pos = tamanho - 7;\n    for (let i = tamanho; i >= 1; i--) {\n        soma += numeros.charAt(tamanho - i) * pos--;\n        if (pos < 2) pos = 9;\n    }\n    let resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11);\n    if (resultado != digitos.charAt(0)) return false;\n    tamanho = tamanho + 1;\n    numeros = cnpj.substring(0, tamanho);\n    soma = 0;\n    pos = tamanho - 7;\n    for (let i = tamanho; i >= 1; i--) {\n        soma += numeros.charAt(tamanho - i) * pos--;\n        if (pos < 2) pos = 9;\n    }\n    resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11);\n    return resultado == digitos.charAt(1);\n}\n\nconst cnpjValido = validarCNPJ(cnpjBruto) ? cnpjBruto : null;\n\nreturn [{\n  json: {\n    dados_extraidos: {\n      novo_email: emailMatch ? emailMatch[0] : null,\n      novo_cnpj: cnpjValido\n    }\n  }\n}];"
      },
