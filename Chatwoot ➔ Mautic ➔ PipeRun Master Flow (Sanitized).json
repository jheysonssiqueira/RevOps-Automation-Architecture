    {
      "parameters": {
        "jsCode": "// 1. Pega os cards que o PipeRun achou pelo telefone\nconst inputData = $input.all()[0].json.data;\n\n// 2. Procura o card que pertence ESTRITAMENTE ao Funil de Marketing (ID 9619)\nlet meuDeal = inputData ? inputData.find(d => d.pipeline_id === 9619) : null;\n\n// 3. O CADEADO DE TITÂNIO: Se não achar no funil de Marketing, morre aqui! (Sem gambiarras)\nif (!meuDeal) {\n    throw new Error('CADEADO ATIVO: Cliente não está no Funil de Marketing do PipeRun. Ignorando injeção de dados.');\n}\n\n// 4. Busca os dados extraídos pelo RegEx local (E-mail e CNPJ)\nconst dadosExtraidos = $('Extrator Local (Sem Erros)').first().json.dados_extraidos;\n\nreturn [{\n  json: {\n    deal_id: meuDeal.id,\n    company_id: meuDeal.company_id,\n    novo_email: dadosExtraidos.novo_email,\n    novo_cnpj: dadosExtraidos.novo_cnpj,\n    texto_nota: `🤖 [SISTEMA DE DADOS]\\nO cliente informou novos dados no WhatsApp:\\n📧 E-mail: ${dadosExtraidos.novo_email || 'Não informado'}\\n🏢 CNPJ: ${dadosExtraidos.novo_cnpj || 'Não informado'}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        256
      ],
